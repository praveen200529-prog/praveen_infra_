{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/portal",
      "destination": "/portal/login",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://praveen-infra.onrender.com/api/$1"
    },
    {
      "source": "/portal/api/(.*)",
      "destination": "https://praveen-infra.onrender.com/portal/api/$1"
    },
    {
      "source": "/portal/uploads/(.*)",
      "destination": "https://praveen-infra.onrender.com/portal/uploads/$1"
    }
  ]
}
